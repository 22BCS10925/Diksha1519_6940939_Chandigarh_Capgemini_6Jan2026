@model List<WeeklyTestEmployee.Models.Employee>

<h2>Employees List</h2>

<a href="/Employees/Create">Add Employee</a>

<table border="1">

<tr>
<th>ID</th>
<th>Name</th>
<th>Department</th>
<th>Projects</th>
</tr>

@foreach(var emp in Model)
{
<tr>

<td>@emp.EmployeeId</td>

<td>@emp.Name</td>

<td>@emp.Department?.DepartmentName</td>

<td>

@foreach(var ep in emp.EmployeeProjects)
{
@ep.Project.Title <br>
}

</td>

</tr>
}

</table>