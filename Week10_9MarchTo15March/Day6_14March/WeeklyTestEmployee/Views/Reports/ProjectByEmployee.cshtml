@model List<WeeklyTestEmployee.Models.Project>

<h2>Projects Assigned To Employee</h2>

<table border="1">

    <tr>
        <th>Project ID</th>
        <th>Title</th>
    </tr>

    @foreach (var p in Model)
    {

        <tr>

            <td>@p.ProjectId</td>

            <td>@p.Title</td>

        </tr>

    }

</table>