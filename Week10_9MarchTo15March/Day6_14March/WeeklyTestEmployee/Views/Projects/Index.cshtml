@model List<WeeklyTestEmployee.Models.Project>

<h2>Projects List</h2>

<a href="/Projects/Create">Add Project</a>

<table border="1">

<tr>
<th>ID</th>
<th>Title</th>
<th>Employees</th>
</tr>

@foreach(var p in Model)
{

<tr>

<td>@p.ProjectId</td>

<td>@p.Title</td>

<td>

@foreach(var ep in p.EmployeeProjects)
{
@ep.Employee.Name <br>
}

</td>

</tr>

}

</table>