@model IEnumerable<LibraryManagement.Models.Library>

<h2>Book List</h2>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Title</th>
        @* <th>Author</th> *@
        <th>Action</th>
    </tr>

    @foreach (var book in Model)
    {
        <tr>
            <td>@book.Id</td>
            <td>@book.Title</td>
            @* <td>@book.Author</td> *@
            <td>
                <a asp-action="Details" asp-route-id="@book.Id">View</a>
            </td>
        </tr>
    }

</table>