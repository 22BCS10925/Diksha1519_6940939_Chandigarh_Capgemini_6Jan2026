@model IEnumerable<SecureEmployee.Models.Employee>

<h2>Employee List</h2>
<p>User Role Check:</p>
<p>Is Admin: @User.IsInRole("Admin")</p>
<p>Is Employee: @User.IsInRole("Employee")</p>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary">Add Employee</a>
}

<table class="table">
    <tr>
        <th>Name</th>
        <th>Department</th>
        <th>Salary</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Department</td>
            <td>@item.Salary</td>
            <td>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                }
            </td>
        </tr>
    }
</table>