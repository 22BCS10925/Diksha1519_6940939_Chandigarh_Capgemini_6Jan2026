@model WebApplication1.Models.Product
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">
    <h2>Add Product</h2>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken() <!-- ✅ This is required -->

        <div asp-validation-summary="ModelOnly" class="text-danger"></div> <!-- ✅ Show errors -->

        <div class="mb-3">
            <label>Name</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Description</label>
            <input asp-for="Description" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Price</label>
            <input asp-for="Price" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Image URL</label>
            <input asp-for="ImageUrl" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Category</label>
            <select asp-for="CategoryId" class="form-control"
                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Save</button>
        <a href="/Product/Index" class="btn btn-secondary">Back</a>
    </form>
</div>