@model IEnumerable<WebApplication1.Models.Product>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<p>User: @User.Identity.Name</p>
<p>Is Admin: @User.IsInRole("Admin")</p>
<div class="container mt-4">
    <h2 class="mb-3">Products</h2>

    <!-- ✅ Admin Add Button -->
    @if (User.IsInRole("Admin"))
    {
        <a href="/Product/Create" class="btn btn-success mb-3">Add Product</a>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card mb-3 shadow-sm">

                    <!-- ✅ Image with fallback -->
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300" : item.ImageUrl)"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body">
                        <h5 class="card-title">@item.Name</h5>

                        <!-- ✅ Price formatted -->
                        <p class="card-text text-success fw-bold">
                            ₹ @item.Price.ToString("N2")
                        </p>

                        <!-- ✅ Null-safe Category -->
                        <p class="card-text text-muted">
                            Category: @(item.Category != null ? item.Category.Name : "N/A")
                        </p>

                        <!-- ✅ Admin Actions -->
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/Product/Edit/@item.Id" class="btn btn-warning btn-sm">Edit</a>
                            <a href="/Product/Delete/@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        }
                        @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                        {
                            <a asp-controller="Order"
                               asp-action="Create"
                               asp-route-productId="@item.Id"
                               class="btn btn-primary btn-sm">
                                Buy Now
                            </a>
                        }

                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a href="/Account/Login" class="btn btn-secondary btn-sm">
                                Login to Buy
                            </a>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
</div>