@{
    ViewData["Title"] = "Billing";
    
    // Helper methods to safely handle JsonElement conversions
    bool GetBoolValue(Dictionary<string, object> dict, string key, bool defaultValue = false)
    {
        if (!dict.ContainsKey(key) || dict[key] == null)
            return defaultValue;
            
        if (dict[key] is System.Text.Json.JsonElement element)
        {
            return element.GetBoolean();
        }
        
        try
        {
            return Convert.ToBoolean(dict[key]);
        }
        catch
        {
            return defaultValue;
        }
    }
    
    DateTime? GetDateTimeValue(Dictionary<string, object> dict, string key)
    {
        if (!dict.ContainsKey(key) || dict[key] == null)
            return null;
            
        if (dict[key] is System.Text.Json.JsonElement element)
        {
            return element.GetDateTime();
        }
        
        try
        {
            return Convert.ToDateTime(dict[key]);
        }
        catch
        {
            return null;
        }
    }
    
    decimal GetDecimalValue(Dictionary<string, object> dict, string key)
    {
        if (!dict.ContainsKey(key) || dict[key] == null)
            return 0;
            
        if (dict[key] is System.Text.Json.JsonElement element)
        {
            return element.GetDecimal();
        }
        
        try
        {
            return Convert.ToDecimal(dict[key]);
        }
        catch
        {
            return 0;
        }
    }
}

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h5 class="mb-0"><i class="bi bi-receipt-cutoff text-primary me-2"></i>Billing Records</h5>
                <small class="text-muted">View consultation and medicine charges</small>
            </div>
        </div>

        @if (ViewBag.Billings != null && ViewBag.Billings.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice</th>
                            <th>Appointment</th>
                            <th>Doctor</th>
                            <th>Patient</th>
                            <th>Consultation</th>
                            <th>Medicine</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in ViewBag.Billings)
                        {
                            <tr>
                                <td>#@bill["id"]</td>
                                <td>#@bill["appointmentId"]</td>
                                <td>@bill["doctorName"]</td>
                                <td>@bill["patientName"]</td>
                                <td>
                                    <span class="badge bg-info">¥@string.Format("{0:F2}", GetDecimalValue(bill, "consultationFee"))</span>
                                </td>
                                <td>
                                    <span class="badge bg-success">¥@string.Format("{0:F2}", GetDecimalValue(bill, "medicineCost"))</span>
                                </td>
                                <td>
                                    <strong class="text-danger">¥@string.Format("{0:F2}", GetDecimalValue(bill, "totalAmount"))</strong>
                                </td>
                                <td>
                                    @{
                                        bool isPaid = GetBoolValue(bill, "isPaid");
                                        if (isPaid)
                                        {
                                            <span class="badge bg-success">Paid</span>
                                            var paidAt = GetDateTimeValue(bill, "paidAt");
                                            if (paidAt.HasValue)
                                            {
                                                <br /><small class="text-muted">@paidAt.Value.ToString("MMM dd, yyyy HH:mm")</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@bill["id"]" class="btn btn-outline-info" title="View details">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        <a asp-controller="Appointments" asp-action="Prescription" asp-route-id="@bill["appointmentId"]" class="btn btn-outline-success" title="View prescription">
                                            <i class="bi bi-file-earmark-medical"></i> Prescription
                                        </a>
                                        @{
                                            if (!isPaid)
                                            {
                                                <button type="button" class="btn btn-outline-warning pay-btn" data-billing-id="@bill["id"]" data-total="@bill["totalAmount"]" title="Pay for this appointment">
                                                    <i class="bi bi-credit-card"></i> Pay
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-outline-success" disabled>
                                                    <i class="bi bi-check-circle"></i> Paid
                                                </button>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-receipt text-primary" style="font-size:3rem"></i>
                <p class="mt-3">No billing records found yet.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Store JWT token for API calls
        const jwtToken = '@(ViewBag.JwtToken ?? "")';

        document.querySelectorAll('.pay-btn').forEach(button => {
            button.addEventListener('click', async function() {
                const billingId = this.dataset.billingId;
                const total = this.dataset.total;

                if (!confirm(`Pay ₹${parseFloat(total).toFixed(2)} for this bill?`)) {
                    return;
                }

                try {
                    const response = await fetch(`https://localhost:7001/api/billings/pay`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': 'Bearer ' + jwtToken
                        },
                        body: JSON.stringify({
                            billingId: parseInt(billingId),
                            amount: parseFloat(total),
                            paymentMethod: "Credit Card",
                            transactionId: "TXN" + Date.now()
                        })
                    });

                    if (response.ok) {
                        const result = await response.json();
                        alert('Payment successful! Status: ' + result.status);
                        location.reload();
                    } else {
                        const error = await response.json();
                        alert('Payment failed: ' + (error.message || 'Unknown error'));
                    }
                } catch (error) {
                    alert('Error processing payment: ' + error.message);
                }
            });
        });
    </script>
}

