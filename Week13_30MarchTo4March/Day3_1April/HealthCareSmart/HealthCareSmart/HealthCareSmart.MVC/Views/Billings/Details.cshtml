@{
    ViewData["Title"] = "Billing Details";
    var bill = ViewBag.Billing as Dictionary<string, object> ?? new Dictionary<string, object>();
    
    // Helper methods to safely handle JsonElement conversions
    bool GetBoolValue(Dictionary<string, object> dict, string key, bool defaultValue = false)
    {
        if (!dict.ContainsKey(key) || dict[key] == null)
            return defaultValue;
            
        if (dict[key] is System.Text.Json.JsonElement element)
        {
            return element.GetBoolean();
        }
        
        try
        {
            return Convert.ToBoolean(dict[key]);
        }
        catch
        {
            return defaultValue;
        }
    }
    
    DateTime? GetDateTimeValue(Dictionary<string, object> dict, string key)
    {
        if (!dict.ContainsKey(key) || dict[key] == null)
            return null;
            
        if (dict[key] is System.Text.Json.JsonElement element)
        {
            return element.GetDateTime();
        }
        
        try
        {
            return Convert.ToDateTime(dict[key]);
        }
        catch
        {
            return null;
        }
    }
    
    decimal GetDecimalValue(Dictionary<string, object> dict, string key)
    {
        if (!dict.ContainsKey(key) || dict[key] == null)
            return 0;
            
        if (dict[key] is System.Text.Json.JsonElement element)
        {
            return element.GetDecimal();
        }
        
        try
        {
            return Convert.ToDecimal(dict[key]);
        }
        catch
        {
            return 0;
        }
    }
}

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h5 class="mb-0"><i class="bi bi-receipt text-primary me-2"></i>Invoice #@bill["id"]</h5>
                <small class="text-muted">Detailed charges for this consultation</small>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Billing</a>
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-3">Appointment ID</dt>
            <dd class="col-sm-9">@bill["appointmentId"]</dd>

            <dt class="col-sm-3">Doctor</dt>
            <dd class="col-sm-9">@bill["doctorName"]</dd>

            <dt class="col-sm-3">Patient</dt>
            <dd class="col-sm-9">@bill["patientName"]</dd>

            <dt class="col-sm-3">Invoice Date</dt>
            <dd class="col-sm-9">@bill["createdAt"]</dd>

            <dt class="col-sm-3">Payment Status</dt>
            <dd class="col-sm-9">
                @{
                    bool isPaid = GetBoolValue(bill, "isPaid");
                    if (isPaid)
                    {
                        <span class="badge bg-success fs-6">Paid</span>
                        var paidAt = GetDateTimeValue(bill, "paidAt");
                        if (paidAt.HasValue)
                        {
                            <br /><small class="text-muted">Paid on: @paidAt.Value.ToString("MMM dd, yyyy HH:mm")</small>
                        }
                    }
                    else
                    {
                        <span class="badge bg-warning fs-6">Pending</span>
                    }
                }
            </dd>
        </dl>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="card bg-light p-3">
                    <h6>Consultation Fee</h6>
                    <p class="fs-4 mb-0">@string.Format("{0:C}", GetDecimalValue(bill, "consultationFee"))</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light p-3">
                    <h6>Medicine Charges</h6>
                    <p class="fs-4 mb-0">@string.Format("{0:C}", GetDecimalValue(bill, "medicineCost"))</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-primary text-white p-3">
                    <h6>Total Amount</h6>
                    <p class="fs-4 mb-0">@string.Format("{0:C}", GetDecimalValue(bill, "totalAmount"))</p>
                </div>
            </div>
        </div>
    </div>
</div>
