@model SmartHealthcare.Models.Entities.Bill

@{
    ViewData["Title"] = "Create Bill";
}

<h2>Create Bill</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Appointment ID</label>
        <input asp-for="AppointmentId" class="form-control" />
    </div>
    <div class="form-group">
        <label>Consultation Fee</label>
        <input asp-for="ConsultationFee" class="form-control" />
    </div>
    <div class="form-group">
        <label>Medicine Charges</label>
        <input asp-for="MedicineCharges" class="form-control" />
    </div>
    <div class="form-group">
        <label>Payment Status</label>
        <select asp-for="PaymentStatus" class="form-control">
            <option>Paid</option>
            <option>Unpaid</option>
        </select>
    </div>
    <button type="submit" class="btn btn-success">Save</button>
</form>